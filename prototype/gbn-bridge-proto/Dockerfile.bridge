# syntax=docker/dockerfile:1

FROM rust:1-bookworm AS builder
WORKDIR /workspace
COPY . .
RUN cargo build --release -p gbn-bridge-cli --bin exit-bridge

FROM debian:bookworm-slim
RUN useradd --create-home --uid 10001 veritas
USER veritas
WORKDIR /app
COPY --from=builder /workspace/target/release/exit-bridge /usr/local/bin/exit-bridge
ENV GBN_BRIDGE_ROLE=exit-bridge \
    GBN_BRIDGE_RUN_MODE=serve \
    GBN_BRIDGE_PUNCH_PORT=443 \
    GBN_BRIDGE_BATCH_WINDOW_MS=500
EXPOSE 443/udp
ENTRYPOINT ["/usr/local/bin/exit-bridge"]
CMD ["--serve"]
